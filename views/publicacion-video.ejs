<!DOCTYPE html>
<html lang="es">
<%- include("fragments/head") %>

<body class="d-flex flex-column min-vh-100 bg-light">
    <%- include("fragments/header") %>
    <%- include("fragments/navbar") %>

    <% if (locals.mensajeExito) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-check-circle me-2"></i>
            <%= mensajeExito %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>
    <% if (locals.mensajeError) { %>
        <div id="mensajeError" class="alert alert-danger d-none alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-exclamation-triangle me-2"></i>
            <span class="mensaje-texto"><%= mensajeError %></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } else { %>
        <div id="mensajeError" class="alert alert-danger d-none alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-exclamation-triangle me-2"></i>
            <span class="mensaje-texto"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <div id="popup-publicar" class="alert alert-danger position-fixed top-50 start-50 translate-middle shadow-lg border-0 d-none" role="alert" style="z-index: 1050; min-width: 320px; max-width: 90%;">
        <span id="popup-publicar-text"></span>
    </div>

    <main class="flex-grow-1 publicacion-video-page py-5">
        <div class="container">
            <section class="mb-4 publicacion-video-hero rounded-4 p-4 p-md-5 shadow-sm text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="d-flex flex-column flex-md-row align-items-start justify-content-between gap-3">
                    <div>
                        <span class="badge text-white mb-3 bg-primary">Publicación de video</span>
                        <h1 class="h3 fw-bold mb-2">Crea tu publicación al estilo YouTube</h1>
                        <p class="mb-0 text-white-75">Revisa la previsualización y completa los detalles antes de subirlo a YouTube.</p>
                    </div>
                    <div class="text-md-end">
                        <a href="/usuario/publicar-video" class="btn btn-outline-light rounded-pill px-4 py-2">Volver a la galería</a>
                    </div>
                </div>
            </section>

            <section class="row g-4">
                <div class="col-lg-7">
                    <article class="card publicacion-video-card rounded-4 shadow-sm border-0 bg-white h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <h2 class="h5 mb-0 fw-bold">Previsualización del video</h2>
                                <span class="badge bg-light text-dark shadow-sm border">YouTube Style</span>
                            </div>

                            <div class="video-preview-wrapper rounded-4 overflow-hidden mb-3 bg-dark" style="aspect-ratio: 16/9; display: flex; align-items: center;">
                                <video id="preview-video" class="w-100 h-100" controls playsinline src="<%= videoUrl %>">
                                    Tu navegador no soporta la etiqueta de video.
                                </video>
                            </div>

                            <p id="preview-info" class="text-muted mb-0 small">
                                <i class="fa-solid fa-circle-info me-1"></i> Previsualizando archivo seleccionado de tu biblioteca NexusHub.
                            </p>
                        </div>
                    </article>
                </div>

                <div class="col-lg-5">
                    <article class="card publicacion-video-card rounded-4 shadow-sm border-0 bg-white h-100">
                        <div class="card-body p-4">
                            <h2 class="h5 fw-bold mb-4">Detalles de la publicación</h2>

                            <form id="form-publicacion-video" class="publicacion-form" method="post" action="/usuario/api/youtube/subir-video">
                                
                                <input id="duracion-video" type="hidden" value="<%= duracionSegundos || 0 %>">
                                <input type="hidden" name="videoUrl" value="<%= videoUrl %>">

                                <div class="mb-4">
                                    <label for="titulo-video" class="form-label fw-semibold">Título</label>
                                    <input id="titulo-video" name="titulo" class="form-control" type="text" maxlength="100" placeholder="Ej. Cómo crear contenido viral en NexusHub" required>
                                    <div class="form-text">Hazlo claro, descriptivo y atractivo para tu audiencia.</div>
                                </div>

                                <div class="mb-4">
                                    <label for="descripcion-video" class="form-label fw-semibold">Descripción</label>
                                    <textarea id="descripcion-video" name="descripcion" class="form-control" rows="6" maxlength="5000" placeholder="Describe el contenido del video, añade hashtags o enlaces útiles." required></textarea>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-semibold">Privacidad del video</label>
                                    <div class="d-flex flex-column gap-2">
                                        <label class="form-check form-check-inline">
                                            <input class="form-check-input privacy-checkbox" type="checkbox" name="privacyStatus" value="private" checked>
                                            <span class="form-check-label">Privado</span>
                                        </label>
                                        <label class="form-check form-check-inline">
                                            <input class="form-check-input privacy-checkbox" type="checkbox" name="privacyStatus" value="unlisted">
                                            <span class="form-check-label">No listado</span>
                                        </label>
                                        <label class="form-check form-check-inline">
                                            <input class="form-check-input privacy-checkbox" type="checkbox" name="privacyStatus" value="public">
                                            <span class="form-check-label">Público</span>
                                        </label>
                                    </div>
                                    <div class="form-text">Selecciona el estado de privacidad para la publicación en YouTube.</div>
                                </div>

                                <div class="d-flex flex-column gap-3">
                                    <button type="submit" class="btn btn-danger rounded-pill px-4 py-2 fw-bold">
                                        <i class="fa-brands fa-youtube me-2"></i>Publicar en YouTube
                                    </button>
                                    <button type="button" id="btn-reset-form" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                                        Limpiar textos
                                    </button>
                                </div>
                            </form>
                        </div>
                    </article>
                </div>
            </section>
        </div>
    </main>

    <%- include("fragments/footer") %>

    <script>
        const resetButton = document.getElementById('btn-reset-form');
        const privacyCheckboxes = document.querySelectorAll('.privacy-checkbox');

        if (resetButton) {
            resetButton.addEventListener('click', () => {
                if (confirm('¿Estás seguro de que quieres borrar el título y la descripción?')) {
                    document.getElementById('titulo-video').value = '';
                    document.getElementById('descripcion-video').value = '';
                }
            });
        }

        if (privacyCheckboxes.length > 0) {
            privacyCheckboxes.forEach((checkbox) => {
                checkbox.addEventListener('change', () => {
                    if (checkbox.checked) {
                        privacyCheckboxes.forEach((other) => {
                            if (other !== checkbox) {
                                other.checked = false;
                            }
                        });
                    } else {
                        const anyChecked = Array.from(privacyCheckboxes).some((item) => item.checked);
                        if (!anyChecked) {
                            checkbox.checked = true;
                        }
                    }
                });
            });
        }

        const formPublicacion = document.getElementById('form-publicacion-video');
        const tituloInput = document.getElementById('titulo-video');
        const descripcionInput = document.getElementById('descripcion-video');
        const mensajeErrorBox = document.getElementById('mensajeError');
        const mensajeTexto = mensajeErrorBox?.querySelector('.mensaje-texto');
        const duracionVideoInput = document.getElementById('duracion-video');
        const duracionVideo = Number(duracionVideoInput?.value || 0);
        const popupPublicar = document.getElementById('popup-publicar');
        const popupPublicarText = document.getElementById('popup-publicar-text');
        const serverErrorMessage = <%- JSON.stringify(mensajeError || null) %>;

        function mostrarPopupPublicar(mensaje) {
            if (!popupPublicar || !popupPublicarText) {
                alert(mensaje);
                return;
            }
            popupPublicarText.textContent = mensaje;
            popupPublicar.classList.remove('d-none');
            if (popupPublicar._timeoutId) {
                clearTimeout(popupPublicar._timeoutId);
            }
            popupPublicar._timeoutId = setTimeout(() => {
                popupPublicar.classList.add('d-none');
            }, 6000);
        }

        if (serverErrorMessage) {
            if (mensajeErrorBox) {
                mensajeErrorBox.classList.add('d-none');
            }
            mostrarPopupPublicar(serverErrorMessage);
        }

        if (formPublicacion && tituloInput && descripcionInput && mensajeErrorBox) {
            formPublicacion.addEventListener('submit', (event) => {
                if (duracionVideo >= 12 * 60 * 60) {
                    event.preventDefault();
                    mostrarPopupPublicar('Error: video demasiado largo, debe durar menos de 12 horas');
                    return;
                }

                const titulo = tituloInput.value.trim();
                const descripcion = descripcionInput.value.trim();

                if (!titulo || !descripcion) {
                    event.preventDefault();
                    mensajeErrorBox.classList.remove('d-none');
                    mensajeErrorBox.classList.add('alert', 'alert-danger', 'fade', 'show');
                    if (mensajeTexto) {
                        mensajeTexto.textContent = 'Debes completar el título y la descripción antes de publicar en YouTube.';
                    } else {
                        mensajeErrorBox.innerHTML = '<i class="fa-solid fa-exclamation-triangle me-2"></i>Debes completar el título y la descripción antes de publicar en YouTube.<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
                    }
                    mensajeErrorBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        }
    </script>
</body>
</html>