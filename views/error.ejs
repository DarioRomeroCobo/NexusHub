<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
<%- include("fragments/head") %>

<body class="d-flex flex-column min-vh-100">
    <%- include("fragments/header") %>
    <%- include("fragments/navbar") %>

    <div class="container text-center mt-5">
        <h1 class="display-3 text-danger"><%= codigo %></h1>
        <h2 class="mb-3"><%= titulo %></h2>
        <p class="lead"><%= mensaje %></p>

        <!-- Botón actualizado con degradado azul -->
        <a href="/" class="btn btn-gradient mt-3">
            Inicio
        </a>
    </div>

    <%- include("fragments/footer") %>

    <style>
        /* Botón con degradado azul */
        .btn-gradient {
            background: linear-gradient(90deg, #0d6efd, #3a8dde);
            color: #fff;
            transition: all 0.3s ease;
            border: none;
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
        }

        .btn-gradient:hover {
            background: linear-gradient(90deg, #3a8dde, #0d6efd);
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }
    </style>
</body>
</html>