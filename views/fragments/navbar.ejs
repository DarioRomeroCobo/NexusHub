<nav class="navbar navbar-expand-md bg-white sticky-top shadow-sm py-1">
    <div class="container-fluid">
        <% if (!locals.isLoggedIn) { %>
            <a class="navbar-brand d-flex align-items-center" href="/" aria-label="Inicio">
                <img src="/img/logo.png" alt="Logo NexusHub" width="72" height="29" class="img-fluid rounded">
            </a>

            <div class="ms-auto">
                <a href="/usuario/inicio-sesion"
                    class="btn btn-gradient px-4 py-2 rounded-pill fw-semibold me-2"
                    aria-label="Inicio de sesión" title="Ir a la página de inicio de sesión">
                    Inicio de sesión
                </a>
                <a href="/usuario/registro" class="btn btn-gradient px-4 py-2 rounded-pill fw-semibold"
                    aria-label="Registro" title="Ir a la página de registro">
                    Registro
                </a>
            </div>
        <% } else { %>
            <div class="ms-auto">
                <a href="/usuario/subir-video"
                    class="btn btn-gradient px-4 py-2 rounded-pill fw-semibold me-2"
                    aria-label="Subir video" title="Ir a la página de subir video">
