                        <section class="card border-0 shadow-sm rounded-4 p-3 p-md-4 bg-white">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                                <h2 class="h5 mb-0 fw-bold">Listado de videos subidos</h2>
                                <span class="badge text-bg-light border">Total: <%= totalVideos %></span>
                            </div>

                            <% if (!videos || videos.length===0) { %>
                                <div class="text-center py-5 text-muted">
                                    <p class="mb-2 fw-semibold">Todavía no has subido videos.</p>
                                    <p class="mb-0">Pulsa en "Subir nuevo video" para cargar el primero.</p>
                                </div>
                                <% } else { %>
                                    <div class="table-responsive">
                                        <table class="table align-middle mb-0">
                                            <thead>
                                                <tr>
                                                    <th scope="col">Nombre del video</th>
                                                    <th scope="col">Tamaño</th>
                                                    <th scope="col">Duración</th>
                                                    <th scope="col">Hora de subida</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% videos.forEach(function(video) { %>
                                                    <tr>
                                                        <td class="fw-semibold">
                                                            <%= video.nombre %>
                                                        </td>
                                                        <td>
                                                            <%= video.pesoMB %> MB
                                                        </td>
                                                        <td>
                                                            <%= video.duracionSegundos %> s
                                                        </td>
                                                        <td>
                                                            <%= video.fecha ? new
                                                                Date(video.fecha).toLocaleString('es-ES')
                                                                : 'Fecha no disponible' %>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                            </tbody>
                                        </table>
                                    </div>
                                    <% } %>
                        </section>
                    </div>
                </main>

                <%- include("fragments/footer") %>

                    <script src="/js/scripts-subir-video.js"></script>
    </body>

</html>