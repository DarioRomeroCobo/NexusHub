<!DOCTYPE html>
<html lang="es">
<%- include("fragments/head") %>

<body class="d-flex flex-column min-vh-100 bg-light">
    <%- include("fragments/header") %>
    <%- include("fragments/navbar") %>

    <main class="flex-grow-1 subir-video-page py-4 py-md-5">
        <div class="container">
            <section class="subir-video-hero rounded-4 p-4 p-md-5 mb-4 shadow-sm">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div>
                        <h1 class="h3 h2-md fw-bold mb-1 text-white">Tus videos</h1>
                        <p class="mb-0 text-white-50">Aquí puedes gestionar todos los videos que has subido.</p>
                    </div>

                    <div class="text-end">
                        <button id="btn-subir-nuevo-video" type="button" class="btn btn-gradient rounded-pill fw-semibold px-4 py-2">
                            Subir nuevo video
                        </button>
                    </div>
                </div>

                <div id="subida-feedback" class="alert mt-3 mb-0 d-none" role="alert"></div>

                <form id="form-subir-video" class="d-none" enctype="multipart/form-data">
                    <input id="input-video" type="file" name="video" accept="video/mp4,video/quicktime,.mp4,.mov">
                </form>
            </section>

            <section class="card border-0 shadow-sm rounded-4 p-3 p-md-4 bg-white">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h2 class="h5 mb-0 fw-bold">Listado de videos subidos</h2>
                    <span class="badge text-bg-light border">Total: <%= totalVideos %></span>
                </div>

                <% if (!videos || videos.length === 0) { %>
                    <div class="text-center py-5 text-muted">
                        <p class="mb-2 fw-semibold">Todavía no has subido videos.</p>
                        <p class="mb-0">Pulsa en "Subir nuevo video" para cargar el primero.</p>
                    </div>
                <% } else { %>
                    <div class="row g-4">
                        <% videos.forEach(function(video) { %>
                            <article class="col-12 col-md-6 col-xl-4">
                                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                                    <video class="w-100 video-preview" controls preload="metadata">
                                        <source src="<%= video.url %>" type="video/mp4">
                                        Tu navegador no soporta la reproducción de video.
                                    </video>

                                    <div class="card-body">
                                        <h3 class="h6 fw-bold mb-2 text-truncate" title="<%= video.nombre %>"><%= video.nombre %></h3>
                                        <p class="mb-1 text-muted small">Peso: <%= video.pesoMB %> MB</p>
                                        <p class="mb-0 text-muted small">
                                            Subido: <%= video.fecha ? new Date(video.fecha).toLocaleString('es-ES') : 'Fecha no disponible' %>
                                        </p>
                                    </div>
                                </div>
                            </article>
                        <% }); %>
                    </div>
                <% } %>
            </section>
        </div>
    </main>

    <%- include("fragments/footer") %>

    <script src="/js/scripts-subir-video.js"></script>
</body>
</html>
