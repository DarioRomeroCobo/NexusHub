<!DOCTYPE html>
<html lang="es">
<%- include("fragments/head") %>

<body class="d-flex flex-column min-vh-100 bg-light">
    <%- include("fragments/header") %>
    <%- include("fragments/navbar") %>

    <main class="flex-grow-1 subir-video-page py-4 py-md-5">
        <div class="container">
            <!-- SECCIÓN DE ARCHIVOS -->
            <section class="subir-video-hero rounded-4 p-4 p-md-5 mb-4 shadow-sm">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div>
                        <h1 class="h3 h2-md fw-bold mb-1 text-white">Tus archivos</h1>
                        <p class="mb-0 text-white" style="opacity: 0.85;">Aquí puedes gestionar todos los videos y fotos que has subido.</p>
                    </div>

                    <div class="text-end d-flex gap-2 flex-wrap justify-content-end">
                        <button id="btn-subir-nuevo-video" type="button" class="btn btn-gradient rounded-pill fw-semibold px-4 py-2 text-white">
                        Subir video
                        </button>
                        <button id="btn-subir-nueva-foto" type="button" class="btn btn-light rounded-pill fw-semibold px-4 py-2 text-dark">
                        Subir foto
                        </button>
                    </div>
                </div>

                <div id="subida-feedback-video" class="alert mt-3 mb-0 d-none text-white border-0 shadow-sm" role="alert"></div>
                <div id="subida-feedback-foto" class="alert mt-3 mb-0 d-none text-white border-0 shadow-sm" role="alert"></div>

                <form id="form-subir-video" class="d-none" enctype="multipart/form-data">
                    <input id="input-video" type="file" name="video" accept="video/mp4,video/quicktime,.mp4,.mov">
                </form>
                <form id="form-subir-foto" class="d-none" enctype="multipart/form-data">
                    <input id="input-foto" type="file" name="foto" accept="image/jpeg,image/png,.jpg,.png">
                </form>
            </section>

            <section class="card border-0 shadow-sm rounded-4 p-3 p-md-4 bg-white">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <h2 class="h5 mb-0 fw-bold">Listado de archivos</h2>
                    <span class="badge text-bg-light border">Total: <%= (videos ? videos.length : 0) + (fotos ? fotos.length : 0) %></span>
                </div>

                <% 
                    let archivos = [];
                    if (videos && videos.length > 0) {
                        videos.forEach(function(video) {
                            archivos.push({ ...video, tipo: 'video' });
                        });
                    }
                    if (fotos && fotos.length > 0) {
                        fotos.forEach(function(foto) {
                            archivos.push({ ...foto, tipo: 'foto' });
                        });
                    }
                    archivos.sort((a, b) => new Date(b.fecha) - new Date(a.fecha));
                %>

                <% if (archivos.length === 0) { %>
                    <div class="text-center py-5 text-muted">
                        <p class="mb-2 fw-semibold">Todavía no has subido archivos.</p>
                        <p class="mb-0">Pulsa en "Subir archivo" para cargar el primero.</p>
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Nombre</th>
                                    <th scope="col">Tipo</th>
                                    <th scope="col">Tamaño</th>
                                    <th scope="col" class="d-none d-md-table-cell">Información adicional</th>
                                    <th scope="col">Hora de subida</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% archivos.forEach(function(archivo) { %>
                                    <tr>
                                        <td class="fw-semibold"><%= archivo.nombre %></td>
                                        <td>
                                            <% if (archivo.tipo === 'video') { %>
                                                <span class="badge bg-primary">Video</span>
                                            <% } else { %>
                                                <span class="badge bg-info">Foto</span>
                                            <% } %>
                                        </td>
                                        <td><%= archivo.pesoMB %> MB</td>
                                        <td class="d-none d-md-table-cell">
                                            <% if (archivo.tipo === 'video') { %>
                                                Duración: <%= archivo.duracionSegundos %> s
                                            <% } else { %>
                                                ---
                                            <% } %>
                                        </td>
                                        <td><%= archivo.fecha ? new Date(archivo.fecha).toLocaleString('es-ES') : 'Fecha no disponible' %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </section>
        </div>
    </main>

    <%- include("fragments/footer") %>

    <script src="/js/scripts-subir-video.js"></script>
    <script src="/js/scripts-subir-foto.js"></script>
</body>
</html>
