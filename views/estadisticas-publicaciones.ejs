<!DOCTYPE html>
<html lang="es">
<%- include("fragments/head") %>

    <body class="d-flex flex-column min-vh-100 bg-light">
        <%- include("fragments/header") %>
            <%- include("fragments/navbar") %>

                <main class="flex-grow-1 py-4 py-md-5">
                    <div class="container">
                        <section class="card stats-hero-card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white mb-4">
                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                                <div>
                                    <h1 class="h3 fw-bold mb-1 text-white">Estadísticas de tus últimas 5 publicaciones</h1>
                                    <p class=" mb-0 text-white">
                                        <% if (canal) { %>
                                            Canal de YouTube: <span class="fw-semibold">
                                                <%= canal %>
                                            </span>
                                        <% }  %>
                                           
                                    </p>
                                </div>
                                <span class="badge text-bg-light border fs-6">Total: <%= totalPublicaciones || 0 %></span>
                            </div>
                            <p class="small mt-3 mb-0 text-white-50">
                                Última actualización: <%= ultimaActualizacion ? new
                                    Date(ultimaActualizacion).toLocaleString('es-ES') : 'No disponible' %>
                            </p>
                        </section>

                        <% if (error) { %>
                            <section class="alert alert-warning rounded-4 shadow-sm" role="alert">
                                <h2 class="h6 fw-bold mb-2">No se pudieron cargar las estadísticas</h2>
                                <p class="mb-3">
                                    <%= error %>
                                </p>
                                <a href="/usuario/vincular-youtube"
                                    class="btn btn-gradient rounded-pill px-4 py-2 fw-semibold">
                                    Vincular o renovar YouTube
                                </a>
                            </section>
                            <% } else if (!publicaciones || publicaciones.length===0) { %>
                                <section class="card border-0 shadow-sm rounded-4 p-4 bg-white text-center">
                                    <h2 class="h5 fw-bold mb-2">Aún no hay publicaciones para mostrar</h2>
                                    <p class="text-muted mb-0">Cuando publiques videos en YouTube, aquí verás sus
                                        métricas recientes.</p>
                                    <a href="/usuario/publicar-video" class="btn btn-primary rounded-pill m-3">
                                        Publica ya tus videos
                                    </a>
                                </section>
                                <% } else { %>
                                    <section class="d-flex flex-column gap-3">
                                        <% publicaciones.forEach(function(publicacion) { %>
                                            <article class="card border-0 shadow-sm rounded-4 p-3 p-md-4 bg-white">
                                                <div class="row g-3 align-items-center">
                                                    <div class="col-12 col-md-3 col-lg-2">
                                                        <img src="<%= publicacion.miniatura %>"
                                                            class="img-fluid rounded-3"
                                                            alt="Miniatura de <%= publicacion.titulo %>">
                                                    </div>
                                                    <div class="col-12 col-md-9 col-lg-10">
                                                        <div
                                                            class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
                                                            <h2 class="h4 fw-bold mb-0">
                                                                <%= publicacion.titulo %>
                                                            </h2>
                                                            <span class="text-muted small">
                                                                <%= publicacion.fechaPublicacion ? new
                                                                    Date(publicacion.fechaPublicacion).toLocaleDateString('es-ES')
                                                                    : 'Sin fecha' %>
                                                            </span>
                                                        </div>
                                                        <div class="d-flex flex-wrap gap-2 mb-3">
                                                                <span class="badge text-bg-light border fs-6">👁️ Visualizaciones: <%=
                                                                    publicacion.vistas.toLocaleString('es-ES') %></span>
                                                                <span class="badge text-bg-light border fs-6">👍 Me gusta: <%=
                                                                    publicacion.meGusta.toLocaleString('es-ES') %>
                                                                    </span>
                                                                <span class="badge text-bg-light border fs-6">👎 No me gusta: <%=
                                                                publicacion.noMeGusta.toLocaleString('es-ES') %>
                                                                </span>
                                                                <span class="badge text-bg-light border fs-6">💬 Comentarios: <%=
                                                                    publicacion.comentarios.toLocaleString('es-ES') %>
                                                                    </span>
                                                                <span class="badge text-bg-light border fs-6">💰 Monetización: <%=
                                                                publicacion.monetizable ? 'SI' : 'NO' %>
                                                                </span>
                                                        </div>
                                                        <a href="<%= publicacion.url %>" target="_blank"
                                                            rel="noopener noreferrer"
                                                            class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                            Ver en YouTube
                                                        </a>
                                                    </div>
                                                </div>
                                            </article>
                                            <% }); %>
                                    </section>
                                    <% } %>
                    </div>
                </main>

                <%- include("fragments/footer") %>
    </body>

</html>